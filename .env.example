# ============================================================
# Database (Postgres no VPS ou Neon free)
# ============================================================
DATABASE_URL=postgresql://emmanuel:CHANGEME@localhost:5432/clinica_estetica
DB_PASSWORD=CHANGEME

# ============================================================
# Auth (NextAuth v5)
# ============================================================
AUTH_SECRET=CHANGEME-32-bytes-random
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Mercado Pago
# ============================================================
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# ============================================================
# Encryption (AES-256, base64-encoded)
# ============================================================
ENCRYPTION_KEY=
ENCRYPTION_IV=

# ============================================================
# Evolution API (self-hosted no VPS, grátis)
# ============================================================
# Em prod aponta para a instância rodando no VPS (porta 8080 ou atrás de Nginx)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CHANGEME-evolution-api-key
EVOLUTION_INSTANCE=eb-bot
EVOLUTION_WEBHOOK_SECRET=CHANGEME-32-bytes-random

# ============================================================
# LLM — Groq (free tier)
# https://console.groq.com/keys
# ============================================================
GROQ_API_KEY=gsk_CHANGEME

# Modelos disponíveis no Groq (free):
#   llama-3.3-70b-versatile  — melhor qualidade, limites mais apertados
#   llama-3.1-8b-instant     — mais rápido, qualidade menor, mais headroom
#   qwen-2.5-32b             — bom para instruções
LLM_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=1024

# ============================================================
# Redis — Upstash (free) ou local
# https://console.upstash.com/
# Free tier: 256MB, 10k commands/day
# Em prod use rediss:// (TLS):
#   REDIS_URL=rediss://default:TOKEN@your-instance.upstash.io:6379
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# Agent Runtime
# ============================================================
AGENT_DEFAULT=consultor-vendas-eb
AGENT_RATE_LIMIT_PER_CONTACT_PER_MINUTE=10

# ============================================================
# Logging / Env
# ============================================================
LOG_LEVEL=info
NODE_ENV=development
